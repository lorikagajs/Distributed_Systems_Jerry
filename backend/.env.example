DATABASE_URL="postgresql://jerry:jerry_secret@localhost:5432/jerry_ecommerce"

PORT=3000

JWT_SECRET="change-me-in-production-use-a-long-random-string"

# Optional: if omitted, product image uploads are stored under backend/uploads/ (dev only)

CLOUDINARY_CLOUD_NAME=your_cloud_name

CLOUDINARY_API_KEY=your_api_key

CLOUDINARY_API_SECRET=your_api_secret

API_PUBLIC_URL=http://localhost:3000

REDIS_URL=redis://localhost:6379

CACHE_TTL=60

OPENAI_API_KEY=your_openai_api_key



# Transactional email

EMAIL_ENABLED=true

# false = send immediately (no Redis). true = queue via BullMQ (requires Redis)

EMAIL_USE_QUEUE=false



# --- Real delivery to Gmail / customer inboxes (use this, NOT Ethereal) ---

# Ethereal (smtp.ethereal.email) only shows mail on ethereal.email — it never delivers to Gmail.

# 1. Enable 2FA on Google account → create App Password: https://myaccount.google.com/apppasswords

# 2. Order emails go to the logged-in user's account email (register/login with that address).

EMAIL_SMTP_SERVICE=gmail

SMTP_HOST=smtp.gmail.com

SMTP_PORT=587

SMTP_USER=your.real@gmail.com

SMTP_PASS=your_16_char_google_app_password

SMTP_FROM="Your Store <your.real@gmail.com>"



# --- Ethereal (fake inbox only — for template preview, not Gmail delivery) ---

# SMTP_HOST=smtp.ethereal.email

# SMTP_PORT=587

# SMTP_USER=xxx@ethereal.email

# SMTP_PASS=xxx

# SMTP_FROM="Dev <xxx@ethereal.email>"

